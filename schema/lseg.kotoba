// Lseg clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace lseg {

    entity Instrument {
        id: string @unique
        symbol: string
        assetClass: string
        exchange: string
        currency: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Quote {
        id: string @unique
        instrumentId: string
        bid: float
        ask: float
        asOf: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Order {
        id: string @unique
        instrumentId: string
        side: string
        quantity: float
        price: float
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Execution {
        id: string @unique
        orderId: string
        quantity: float
        price: float
        executedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity MarketData {
        id: string @unique
        instrumentId: string
        open: float
        high: float
        low: float
        close: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Position {
        id: string @unique
        instrumentId: string
        quantity: float
        avgPrice: float
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
